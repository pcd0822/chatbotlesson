# 로컬 개발용 예시 (netlify dev에서 사용)
# Netlify 대시보드에 등록할 실제 값은 여기에 적지 마세요!

# OpenAI API 키 (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# === 구글 서비스 계정 (가장 쉬운 방법: 두 값 분리) ===
GOOGLE_CLIENT_EMAIL=chatbot-reader@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# === (대안) base64 인코딩한 JSON 한 덩어리로 넣기 ===
# GOOGLE_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2...

# === (대안, 비추) JSON 그대로 — 줄바꿈 때문에 실패하기 쉬움 ===
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
